# Frontend Environment Variables

# Copy this file to .env.local and fill in the values
# cp .env.example .env.local

# Horizon API URL (default: Stellar testnet)
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Stellar Expert Explorer Base URL for transaction verification
NEXT_PUBLIC_EXPLORER_BASE_URL=https://stellar.expert/explorer/testnet/tx

# Friendbot URL for getting test XLM
NEXT_PUBLIC_FRIENDBOT_URL=https://laboratory.stellar.org/#account-creator?network=test

# Network Passphrase (Stellar Testnet)
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Optional: Sentry DSN for error tracking
# Get your DSN from https://sentry.io/
# NEXT_PUBLIC_SENTRY_DSN=

# Optional: Vercel Analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Optional: Feature flags or other configuration
# NEXT_PUBLIC_FEATURE_FLAG_X=true
